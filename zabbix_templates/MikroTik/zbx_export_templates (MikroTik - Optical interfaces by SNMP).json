                                ]
                            },
                            {
                                "type": "DISCARD_UNCHANGED_HEARTBEAT",
                                "parameters": [
                                    "1h"
                                ]
                            }
                        ]
                    }
                ],
                "tags": [
                    {
                        "tag": "target",
                        "value": "mikrotik"
                    }
                ],
                "macros": [
                    {
                        "macro": "{$AVERAGE_TRIGGER_INT}",
                        "value": "5m",
                        "description": "How far back to calculate average value for triggers"
                    },
                    {
                        "macro": "{$OPT.IF.NAME.MATCHES}",
                        "value": "^(sfp|combo)"
                    },
                    {
                        "macro": "{$OPT.IF.RXLASER.NOT_MATCHES}",
