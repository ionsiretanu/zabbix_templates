                                "uuid": "22332d9dbe664eb188e31ef6404b13db",
                                "name": "SFP [{#IFNAME}]: Vendor Name",
                                "type": "DEPENDENT",
                                "key": "mtxrOpticalVendor.[{#SNMPINDEX}]",
                                "history": "{$HISTORY}",
                                "value_type": "TEXT",
                                "preprocessing": [
                                    {
                                        "type": "SNMP_WALK_VALUE",
                                        "parameters": [
                                            "1.3.6.1.4.1.14988.1.1.19.1.1.11.{#SNMPINDEX}",
                                            "0"
                                        ],
                                        "error_handler": "CUSTOM_VALUE",
                                        "error_handler_params": "unknown"
                                    },
                                    {
                                        "type": "DISCARD_UNCHANGED_HEARTBEAT",
                                        "parameters": [
                                            "4h"
                                        ]
                                    }
                                ],
                                "master_item": {
                                    "key": "opt.if.walk"
                                },
                                "tags": [
                                    {
                                        "tag": "component",
                                        "value": "network"
                                    },
                                    {
                                        "tag": "component",
                                        "value": "optics"
                                    },
                                    {
                                        "tag": "sfp",
                                        "value": "{#IFNAME}"
                                    }
                                ]
                            },
                            {
                                "uuid": "160ef4ee9ccd4937aad4a259ce47ad07",
                                "name": "SFP [{#IFNAME}]: Wavelength",
                                "type": "DEPENDENT",
                                "key": "mtxrOpticalWavelength.[{#SNMPINDEX}]",
                                "history": "{$HISTORY}",
                                "trends": "0",
                                "units": "!nm",
                                "description": "Wavelength of the optical signal in nanometers (nm).",
                                "preprocessing": [
                                    {
                                        "type": "SNMP_WALK_VALUE",
                                        "parameters": [
                                            "1.3.6.1.4.1.14988.1.1.19.1.1.5.{#SNMPINDEX}",
                                            "0"
                                        ]
                                    },
                                    {
                                        "type": "DISCARD_UNCHANGED_HEARTBEAT",
                                        "parameters": [
                                            "4h"
                                        ]
                                    },
                                    {
                                        "type": "MULTIPLIER",
                                        "parameters": [
                                            "0.01"
                                        ]
                                    }
                                ],
                                "master_item": {
                                    "key": "opt.if.walk"
                                },
                                "tags": [
                                    {
                                        "tag": "component",
                                        "value": "network"
                                    },
                                    {
                                        "tag": "component",
                                        "value": "optics"
                                    },
                                    {
                                        "tag": "sfp",
                                        "value": "{#IFNAME}"
                                    }
                                ]
                            }
                        ],
                        "master_item": {
                            "key": "opt.if.walk"
                        },
                        "preprocessing": [
                            {
                                "type": "SNMP_WALK_TO_JSON",
                                "parameters": [
                                    "{#IFNAME}",
                                    "1.3.6.1.4.1.14988.1.1.19.1.1.2",
                                    "0",
