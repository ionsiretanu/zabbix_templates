                "name": "Templates/Network devices"
            }
        ],
        "templates": [
            {
                "uuid": "781dc7f070b24a84a231cebf03d7689e",
                "template": ".Generic by SNMP",
                "name": ".Generic by SNMP",
                "templates": [
                    {
                        "name": ".ICMP Ping"
                    }
                ],
                "groups": [
                    {
                        "name": "ITcare"
                    },
                    {
                        "name": "MikroTik"
                    },
                    {
                        "name": "Templates/Network devices"
                    }
                ],
                "items": [
                    {
                        "uuid": "0d07872957544b4f845e6b6ed088d076",
                        "name": "System contact details",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "get[1.3.6.1.2.1.1.4.0]",
                        "key": "system.contact[sysContact.0]",
                        "delay": "{$SYSTEM_INFO_INT}",
                        "history": "{$HISTORY}",
                        "value_type": "CHAR",
                        "description": "MIB: SNMPv2-MIB\nThe textual identification of the contact person for this managed node, together with information on how to contact this person. If no contact information is known, the value is the zero-length string.",
                        "inventory_link": "CONTACT",
                        "preprocessing": [
                            {
                                "type": "DISCARD_UNCHANGED_HEARTBEAT",
                                "parameters": [
                                    "12h"
                                ]
                            }
                        ],
                        "tags": [
                            {
                                "tag": "component",
                                "value": "system"
                            }
                        ]
                    },
                    {
                        "uuid": "99239c9fc2f941c997a49bcb608915d7",
                        "name": "System description",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "get[1.3.6.1.2.1.1.1.0]",
                        "key": "system.descr[sysDescr.0]",
                        "delay": "{$SYSTEM_INFO_INT}",
                        "history": "{$HISTORY}",
                        "value_type": "CHAR",
                        "description": "MIB: SNMPv2-MIB\nA textual description of the entity. This value should\ninclude the full name and version identification of the system's hardware type, software operating-system, and\nnetworking software.",
                        "preprocessing": [
                            {
                                "type": "DISCARD_UNCHANGED_HEARTBEAT",
                                "parameters": [
                                    "12h"
                                ]
                            }
                        ],
                        "tags": [
                            {
                                "tag": "component",
                                "value": "system"
                            }
                        ]
                    },
                    {
                        "uuid": "304b7a75cb90421a9164a36ca4fe33b9",
                        "name": "Uptime (hardware)",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "get[1.3.6.1.2.1.25.1.1.0]",
                        "key": "system.hw.uptime[hrSystemUptime.0]",
                        "delay": "{$CRITICAL_HEALTH_INT}",
                        "history": "{$HISTORY}",
                        "trends": "0",
                        "units": "uptime",
                        "description": "MIB: HOST-RESOURCES-MIB\nThe amount of time since this host was last initialized. Note that this is different from sysUpTime in the SNMPv2-MIB [RFC1907] because sysUpTime is the uptime of the network management portion of the system.",
                        "preprocessing": [
                            {
                                "type": "CHECK_NOT_SUPPORTED",
                                "parameters": [
                                    "-1"
                                ],
                                "error_handler": "CUSTOM_VALUE",
                                "error_handler_params": "0"
                            },
                            {
                                "type": "MULTIPLIER",
                                "parameters": [
                                    "0.01"
                                ]
                            }
                        ],
                        "tags": [
                            {
                                "tag": "component",
                                "value": "system"
                            }
                        ]
                    },
                    {
                        "uuid": "e4293a72505044b4a7ad027aba5be858",
                        "name": "System location",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "get[1.3.6.1.2.1.1.6.0]",
                        "key": "system.location[sysLocation.0]",
                        "delay": "{$SYSTEM_INFO_INT}",
                        "history": "{$HISTORY}",
                        "value_type": "CHAR",
                        "description": "MIB: SNMPv2-MIB\nPhysical location of the node (e.g., `equipment room`, `3rd floor`). If not provided, the value is a zero-length string.",
                        "inventory_link": "LOCATION",
                        "preprocessing": [
                            {
                                "type": "DISCARD_UNCHANGED_HEARTBEAT",
                                "parameters": [
                                    "12h"
                                ]
                            }
                        ],
                        "tags": [
                            {
                                "tag": "component",
                                "value": "system"
                            }
                        ]
                    },
                    {
                        "uuid": "58abba06dbc94aebb9734d25df61742b",
                        "name": "System name",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "get[1.3.6.1.2.1.1.5.0]",
                        "key": "system.name",
                        "delay": "{$SYSTEM_INFO_INT}",
                        "history": "{$HISTORY}",
                        "value_type": "CHAR",
                        "description": "MIB: SNMPv2-MIB\nAn administratively-assigned name for this managed node.By convention, this is the node's fully-qualified domain name. If the name is unknown, the value is the zero-length string.",
                        "inventory_link": "NAME",
                        "preprocessing": [
                            {
                                "type": "DISCARD_UNCHANGED_HEARTBEAT",
                                "parameters": [
                                    "12h"
                                ]
                            }
                        ],
                        "tags": [
                            {
                                "tag": "component",
                                "value": "system"
                            }
                        ],
                        "triggers": [
                            {
                                "uuid": "c436b61cde6640cc9a061ec84973e93a",
                                "expression": "last(/.Generic by SNMP/system.name,#1)<>last(/.Generic by SNMP/system.name,#2) and length(last(/.Generic by SNMP/system.name))>0",
                                "name": "System name has changed",
                                "event_name": "System name has changed (new name: {ITEM.VALUE})",
                                "priority": "INFO",
                                "description": "The name of the system has changed. Acknowledge to close the problem manually.",
                                "manual_close": "YES",
                                "tags": [
                                    {
                                        "tag": "scope",
                                        "value": "notice"
                                    },
                                    {
                                        "tag": "scope",
                                        "value": "security"
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "uuid": "118c9a7b9b5c407f8bd00a39924c8b71",
                        "name": "Uptime (network)",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "get[1.3.6.1.2.1.1.3.0]",
                        "key": "system.net.uptime[sysUpTime.0]",
                        "delay": "{$CRITICAL_HEALTH_INT}",
                        "history": "{$HISTORY}",
                        "trends": "0",
                        "units": "uptime",
                        "description": "MIB: SNMPv2-MIB\nTime (in hundredths of a second) since the network management portion of the system was last re-initialized.",
                        "preprocessing": [
                            {
                                "type": "MULTIPLIER",
                                "parameters": [
                                    "0.01"
                                ]
                            }
                        ],
                        "tags": [
                            {
                                "tag": "component",
                                "value": "system"
                            }
                        ]
                    },
                    {
                        "uuid": "f911db0b07b54aef996afebb8e6e4785",
                        "name": "System object ID",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "get[1.3.6.1.2.1.1.2.0]",
                        "key": "system.objectid[sysObjectID.0]",
                        "delay": "{$SYSTEM_INFO_INT}",
                        "history": "{$HISTORY}",
                        "value_type": "CHAR",
                        "description": "MIB: SNMPv2-MIB\nThe vendor's authoritative identification of the network management subsystem contained in the entity. This value is allocated within the SMI enterprises subtree (1.3.6.1.4.1) and provides an easy and unambiguous means for determining`what kind of box' is being managed. For example, if vendor`Flintstones, Inc.' was assigned the subtree1.3.6.1.4.1.4242, it could assign the identifier 1.3.6.1.4.1.4242.1.1 to its `Fred Router'.",
                        "preprocessing": [
                            {
                                "type": "DISCARD_UNCHANGED_HEARTBEAT",
                                "parameters": [
                                    "12h"
                                ]
                            }
                        ],
                        "tags": [
                            {
                                "tag": "component",
                                "value": "system"
                            }
                        ]
                    },
                    {
                        "uuid": "ca7b4af97e0446ce905e6d7da3f6be0c",
                        "name": "SNMP agent availability",
                        "type": "INTERNAL",
                        "key": "zabbix[host,snmp,available]",
                        "delay": "{$HEALTH_POLL_INT}",
                        "history": "{$HISTORY}",
                        "trends": "{$TRENDS}",
                        "description": "Availability of SNMP checks on the host. The value of this item corresponds to availability icons in the host list.\nPossible values:\n0 - not available\n1 - available\n2 - unknown",
                        "valuemap": {
                            "name": "zabbix.host.available"
                        },
                        "tags": [
                            {
                                "tag": "component",
                                "value": "health"
                            },
                            {
                                "tag": "component",
                                "value": "network"
                            }
                        ],
                        "triggers": [
                            {
                                "uuid": "dada50b2a3d74ec381174a901e34db17",
                                "expression": "max(/.Generic by SNMP/zabbix[host,snmp,available],{$SNMP.TIMEOUT})=0",
                                "name": "No SNMP data collection",
                                "opdata": "Current state: {ITEM.LASTVALUE1}",
                                "priority": "WARNING",
                                "description": "SNMP is not available for polling. Please check device connectivity and SNMP settings.",
                                "dependencies": [
                                    {
                                        "name": "Unavailable by ICMP ping",
                                        "expression": "max(/.ICMP Ping/icmpping,#3)=0"
                                    }
                                ],
                                "tags": [
                                    {
                                        "tag": "scope",
                                        "value": "availability"
                                    }
                                ]
                            }
                        ]
                    }
                ],
                "tags": [
                    {
                        "tag": "target",
                        "value": "mikrotik"
                    }
                ],
                "macros": [
                    {
                        "macro": "{$CRITICAL_HEALTH_INT}",
                        "value": "30s"
                    },
                    {
                        "macro": "{$DISCOVERY_INT}",
                        "value": "1h",
                        "description": "Discovery rules interval"
                    },
                    {
                        "macro": "{$HEALTH_POLL_INT}",
                        "value": "1m",
                        "description": "ICMP checks, SNMP availability, device Health"
                    },
                    {
                        "macro": "{$HEALTH_TRIGGER_INT}",
                        "value": "5m",
