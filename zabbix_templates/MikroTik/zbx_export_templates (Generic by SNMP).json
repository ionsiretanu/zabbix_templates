                    },
                    {
                        "macro": "{$ICMP_RESPONSE_TIME_WARN}",
                        "value": "0.15",
                        "description": "Warning threshold of the average ICMP response time in seconds."
                    },
                    {
                        "macro": "{$INVENTORY_INT}",
                        "value": "1h",
                        "description": "Firmware, model, serial, OS"
                    },
                    {
                        "macro": "{$NETWORK_POLL_INT}",
                        "value": "1m",
                        "description": "Network health and stats checks"
                    },
                    {
                        "macro": "{$SNMP.TIMEOUT}",
                        "value": "5m",
                        "description": "Time interval for the SNMP availability trigger."
                    },
                    {
                        "macro": "{$SYSTEM_INFO_INT}",
                        "value": "15m",
                        "description": "System name, contact, location, object ID"
                    },
                    {
                        "macro": "{$TRENDS}",
                        "value": "31d"
                    }
                ],
                "valuemaps": [
                    {
                        "uuid": "d992a087b7834e04ab95cc9938695f48",
                        "name": "Service state",
                        "mappings": [
                            {
                                "value": "0",
                                "newvalue": "Down"
                            },
                            {
                                "value": "1",
                                "newvalue": "Up"
                            }
                        ]
                    },
                    {
                        "uuid": "08424e1fe2d14663a09e29cb6576f2d6",
                        "name": "zabbix.host.available",
                        "mappings": [
                            {
                                "value": "0",
                                "newvalue": "not available"
                            },
                            {
                                "value": "1",
                                "newvalue": "available"
                            },
                            {
                                "value": "2",
                                "newvalue": "unknown"
                            }
                        ]
                    }
                ]
            }
        ],
        "triggers": [
            {
                "uuid": "ce87c529142942c482f59c3d43c4333d",
                "expression": "(last(/.Generic by SNMP/system.hw.uptime[hrSystemUptime.0])>0 and last(/.Generic by SNMP/system.hw.uptime[hrSystemUptime.0])<10m) or (last(/.Generic by SNMP/system.hw.uptime[hrSystemUptime.0])=0 and last(/.Generic by SNMP/system.net.uptime[sysUpTime.0])<10m)",
                "name": "Host has been restarted",
                "event_name": "{HOST.NAME} has been restarted (uptime < 10m)",
                "priority": "WARNING",
                "description": "Uptime is less than 10 minutes.",
                "manual_close": "YES",
                "dependencies": [
                    {
                        "name": "No SNMP data collection",
                        "expression": "max(/.Generic by SNMP/zabbix[host,snmp,available],{$SNMP.TIMEOUT})=0"
                    }
                ],
                "tags": [
                    {
                        "tag": "scope",
                        "value": "notice"
                    }
                ]
            }
        ]
    }
}