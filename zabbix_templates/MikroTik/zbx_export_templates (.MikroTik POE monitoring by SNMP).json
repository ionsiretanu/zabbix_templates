                        "filter": {
                            "evaltype": "AND",
                            "conditions": [
                                {
                                    "macro": "{#IFPOESTATUS}",
                                    "value": "{$POE.IF.STATUS.MATCHES}"
                                },
                                {
                                    "macro": "{#IFPOESTATUS}",
                                    "value": "{$POE.IF.STATUS.NOT_MATCHES}",
                                    "operator": "NOT_MATCHES_REGEX"
                                }
                            ]
                        },
                        "description": "Discovering interfaces from IF-MIB.",
