                            {
                                "uuid": "8c1a9ac03c404b7d9a7218fa86ccd6ad",
                                "name": "POE [{#IFPOENAME}]: Current",
                                "type": "DEPENDENT",
                                "key": "mtxrPOECurrent.[{#SNMPINDEX}]",
                                "history": "{$HISTORY}",
                                "trends": "{$TRENDS}",
                                "units": "mA",
                                "preprocessing": [
                                    {
                                        "type": "SNMP_WALK_VALUE",
                                        "parameters": [
