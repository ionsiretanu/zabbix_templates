                "value_type": "FLOAT",
                "description": "MIB: SIAE-ALFOPLUS-MIB\nrbRfFrequency (HD variant) — operating frequency. Raw value in kHz, multiplied by 1000 to store as Hz.",
                "preprocessing": [
                  {
                    "type": "SNMP_WALK_VALUE",
                    "parameters": [
                      "1.3.6.1.4.1.3373.1103.39.2.1.2.{#SNMPINDEX}",
