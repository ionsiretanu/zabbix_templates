            "tags": [
              {
                "tag": "component",
                "value": "raw"
              }
            ]
          },
          {
            "uuid": "4f851cb3ed9a414986ab214c2ee16756",
            "name": "SNMP walk network interfaces",
            "type": "SNMP_AGENT",
            "snmp_oid": "walk[1.3.6.1.2.1.31.1.1.1.1,1.3.6.1.2.1.2.2.1.2,1.3.6.1.2.1.2.2.1.7,1.3.6.1.2.1.2.2.1.8,1.3.6.1.2.1.31.1.1.1.6,1.3.6.1.2.1.31.1.1.1.10,1.3.6.1.2.1.2.2.1.14,1.3.6.1.2.1.2.2.1.20]",
            "key": "net.if.walk",
            "delay": "{$RADIO_POLL_INT}",
            "history": "0",
            "value_type": "TEXT",
            "description": "Master walk for interface LLD. Uses 64-bit HC counters (confirmed on MH-T280).",
            "tags": [
              {
                "tag": "component",
                "value": "raw"
              }
            ]
          }
