                    "recovery_mode": "RECOVERY_EXPRESSION",
                    "recovery_expression": "min(/.Siklu MH Radio/net.wlan.health.rssi[{#SNMPINDEX}],{$HEALTH_TRIGGER_INT})>{$RSL.LOW}+3",
