                      "0"
                    ]
                  },
                  {
                    "type": "DISCARD_UNCHANGED_HEARTBEAT",
                    "parameters": [
                      "3m"
                    ]
                  }
                ],
                "master_item": {
                  "key": "net.wlan.radio.walk"
                },
                "tags": [
                  {
                    "tag": "component",
                    "value": "radio"
                  },
                  {
                    "tag": "interface",
                    "value": "{#IFNAME}"
