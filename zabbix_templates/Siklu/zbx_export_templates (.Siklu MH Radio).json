        "discovery_rules": [
          {
            "uuid": "88d8546a3f6c47f3a5968be797883e8d",
            "name": "Radio interface discovery",
            "type": "DEPENDENT",
            "key": "net.wlan.radio.discovery",
            "delay": "0",
            "filter": {
              "evaltype": "AND",
              "conditions": [
                {
                  "macro": "{#IFNAME}",
                  "value": "^rf-",
                  "formulaid": "A",
                  "operator": "MATCHES_REGEX"
                }
              ]
            },
            "lifetime": "0s",
            "description": "Discovers MH radio interfaces by ifName matching '^rf-'.\nConfirmed on MH-T280: ifIndex 105 = 'rf-209171a' (pattern varies per unit).\nDiscovery via ifName walk — not hardcoded — so any MH model is covered.",
