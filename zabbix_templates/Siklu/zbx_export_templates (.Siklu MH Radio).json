      {
        "uuid": "9822a2059b8f4533ab0b145dcc27567a",
        "template": ".Siklu MH Radio",
        "name": ".Siklu MH Radio",
        "description": "[network-tool]\nmanufacturer = [ \"Siklu\" ]\ndevice_role = [ \"Radio Link\" ]\ndevice_types = [ \"MH-T280\", \"MH-N366\", \"ML2.5-60-35\" ]\n\n# Siklu template → model mapping (verified by live SNMP walk):\n# .Siklu EH Radio:   EH-600T/TX, EH-614TX, EH-1200/F/FX/L/TL/TX, EH-2200F/FX, EH-2500F/FX, EH-5500FD, EH-8010FX/L/H → .31926.2.*\n# .Siklu MH Radio:   MH-T280, MH-N366(?), ML2.5-60-35(?) → .31926.35.* HC-64bit\n# .Siklu B100 Radio: MH-B100-CCS-PoE-MWB → .31926.27.1.*/27.4.* 32-bit\n# .Siklu T200 Radio: MH-T200-CNN/CCC-PoE-MWB → .31926.27.2.* 32-bit\n# MH-N366/ML2.5-60-35: unverified — check live walk before migration",
        "templates": [
          {
            "name": ".Siklu Generic by SNMP"
          }
        ],
        "groups": [
          {
            "name": "Siklu"
          },
          {
            "name": "ITcare"
          },
          {
            "name": "Templates/Wireless"
          }
        ],
        "items": [
          {
            "uuid": "1a2987470f5e4461845409433396819c",
            "name": "System temperature",
            "type": "SNMP_AGENT",
            "snmp_oid": "get[1.3.6.1.4.1.31926.35.1.1.3.1.1.13.105]",
            "key": "sensor.temp.value[rbSysTemperature.0]",
            "delay": "{$HEALTH_POLL_INT}",
            "history": "{$HISTORY}",
            "trends": "{$TRENDS}",
            "units": "°C",
            "value_type": "FLOAT",
            "description": "MIB: SIKLU-MIB\nTemperature at radio interface index 105 (Gauge32, direct degrees C). Hardcoded at ifIndex 105 — MH-T280 always uses this index for the rf interface.",
            "preprocessing": [
              {
                "type": "DISCARD_UNCHANGED_HEARTBEAT",
                "parameters": [
                  "3m"
                ]
              }
            ],
            "tags": [
              {
                "tag": "component",
                "value": "temperature"
              }
            ],
            "triggers": [
              {
                "uuid": "e2a531a2142e49fb85a0e55ba4fe750c",
                "expression": "avg(/.Siklu MH Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})>{$TEMP_WARN}",
                "recovery_mode": "RECOVERY_EXPRESSION",
                "recovery_expression": "max(/.Siklu MH Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})<{$TEMP_WARN}-3",
                "name": "Siklu MH: Temperature is above warning threshold",
                "event_name": "Siklu MH: Temperature {ITEM.LASTVALUE1} is above warning threshold: >{$TEMP_WARN}°C",
                "opdata": "Current: {ITEM.LASTVALUE1}",
                "priority": "WARNING",
                "manual_close": "YES",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "performance"
                  }
                ]
              },
              {
                "uuid": "66276fb551634800a8e298000e080247",
                "expression": "avg(/.Siklu MH Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})>{$TEMP_CRIT}",
                "recovery_mode": "RECOVERY_EXPRESSION",
                "recovery_expression": "max(/.Siklu MH Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})<{$TEMP_CRIT}-3",
                "name": "Siklu MH: Temperature is above critical threshold",
                "event_name": "Siklu MH: Temperature {ITEM.LASTVALUE1} is above critical threshold: >{$TEMP_CRIT}°C",
                "opdata": "Current: {ITEM.LASTVALUE1}",
                "priority": "HIGH",
                "manual_close": "YES",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "performance"
                  }
                ]
              }
            ]
          },
          {
            "uuid": "d84b20621c154da0a729a34eafeec5e3",
            "name": "SNMP walk radio metrics",
            "type": "SNMP_AGENT",
            "snmp_oid": "walk[1.3.6.1.4.1.31926.35.1.1.3.1.1.7,1.3.6.1.4.1.31926.35.1.1.3.1.1.8,1.3.6.1.4.1.31926.35.1.1.3.1.1.9,1.3.6.1.4.1.31926.35.1.1.3.1.1.10,1.3.6.1.4.1.31926.35.1.1.3.1.1.14,1.3.6.1.4.1.31926.35.1.1.3.1.1.15]",
            "key": "net.wlan.radio.walk",
            "delay": "{$RADIO_POLL_INT}",
            "history": "0",
            "value_type": "TEXT",
