        "uuid": "23e713581b654f69b26da6de5035b781",
        "template": ".Siklu B100 Radio",
        "name": ".Siklu B100 Radio",
        "description": "[network-tool]\nmanufacturer = [ \"Siklu\" ]\ndevice_role = [ \"Radio Link\" ]\ndevice_types = [ \"MH-B100-CCS-PoE-MWB\" ]\n\n# Siklu template → model mapping (verified by live SNMP walk):\n# .Siklu EH Radio:   EH-600T/TX, EH-614TX, EH-1200/F/FX/L/TL/TX, EH-2200F/FX, EH-2500F/FX, EH-5500FD, EH-8010FX/L/H → .31926.2.*\n# .Siklu MH Radio:   MH-T280, MH-N366(?), ML2.5-60-35(?) → .31926.35.* HC-64bit\n# .Siklu B100 Radio: MH-B100-CCS-PoE-MWB → .31926.27.1.*/27.4.* 32-bit\n# .Siklu T200 Radio: MH-T200-CNN/CCC-PoE-MWB → .31926.27.2.* 32-bit\n# MH-N366/ML2.5-60-35: unverified — check live walk before migration",
        "templates": [
          {
            "name": ".Siklu Generic by SNMP"
          }
        ],
        "groups": [
          {
            "name": "Siklu"
          },
          {
            "name": "ITcare"
          },
          {
            "name": "Templates/Wireless"
          }
        ],
        "items": [
          {
            "uuid": "2022e038c08443c6a97634b874adcde6",
            "name": "System temperature",
            "type": "SNMP_AGENT",
            "snmp_oid": "get[1.3.6.1.4.1.31926.1.2.0]",
            "key": "sensor.temp.value[rbSysTemperature.0]",
            "delay": "{$HEALTH_POLL_INT}",
            "history": "{$HISTORY}",
            "trends": "{$TRENDS}",
            "units": "°C",
            "value_type": "FLOAT",
            "description": "MIB: SIKLU-MIB\nsikluSysTemperature.0 — same OID as EH series. Confirmed 32°C on MH-B100.",
            "preprocessing": [
              {
                "type": "DISCARD_UNCHANGED_HEARTBEAT",
                "parameters": [
                  "3m"
                ]
              }
            ],
            "tags": [
              {
                "tag": "component",
                "value": "temperature"
              }
            ],
            "triggers": [
              {
                "uuid": "b10078ebac754a2390d32ef24471857c",
                "expression": "avg(/.Siklu B100 Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})>{$TEMP_WARN}",
                "recovery_mode": "RECOVERY_EXPRESSION",
                "recovery_expression": "max(/.Siklu B100 Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})<{$TEMP_WARN}-3",
                "name": "Siklu B100: Temperature is above warning threshold",
                "event_name": "Siklu B100: Temperature {ITEM.LASTVALUE1} is above warning threshold: >{$TEMP_WARN}°C",
                "opdata": "Current: {ITEM.LASTVALUE1}",
                "priority": "WARNING",
                "manual_close": "YES",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "performance"
                  }
                ]
              },
              {
                "uuid": "b100ef0eb4934a22a9dd8c26062f0b78",
                "expression": "avg(/.Siklu B100 Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})>{$TEMP_CRIT}",
                "recovery_mode": "RECOVERY_EXPRESSION",
                "recovery_expression": "max(/.Siklu B100 Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})<{$TEMP_CRIT}-3",
                "name": "Siklu B100: Temperature is above critical threshold",
