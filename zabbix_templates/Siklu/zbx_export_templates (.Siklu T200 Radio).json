          {
            "uuid": "a54dc45d41f74f1f9bf563d79bcf59fa",
            "name": "SNMP walk radio metrics",
            "type": "SNMP_AGENT",
            "snmp_oid": "walk[1.3.6.1.4.1.31926.27.2.1.5,1.3.6.1.4.1.31926.27.2.1.8,1.3.6.1.4.1.31926.27.2.1.9,1.3.6.1.4.1.31926.27.2.1.12,1.3.6.1.4.1.31926.27.2.1.17]",
            "key": "net.wlan.radio.walk",
            "delay": "{$RADIO_POLL_INT}",
            "history": "0",
            "value_type": "TEXT",
            "description": "Master walk for T200 radio table (.31926.27.2.*).\nColumns: linkState?(.5), connState?(.8), MCS(.9), TXpow?(.12), RSSI(.17).\nNote: no CINR column visible in walk — not supported by T200 MIB version.\nConfirmed on 1705-2333-SKT200 (10.12.244.70): RSSI=-68, MCS=7, .12=30.",
            "tags": [
              {
                "tag": "component",
                "value": "raw"
              }
            ]
          },
          {
            "uuid": "abcefdffaa3c4dc08485b691645f14b8",
            "name": "SNMP walk network interfaces",
            "type": "SNMP_AGENT",
            "snmp_oid": "walk[1.3.6.1.2.1.31.1.1.1.1,1.3.6.1.2.1.2.2.1.2,1.3.6.1.2.1.2.2.1.7,1.3.6.1.2.1.2.2.1.8,1.3.6.1.2.1.2.2.1.10,1.3.6.1.2.1.2.2.1.16,1.3.6.1.2.1.2.2.1.14,1.3.6.1.2.1.2.2.1.20]",
