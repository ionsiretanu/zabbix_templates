        "uuid": "fd9570b179bc420c999f78182b951940",
        "template": ".Siklu T200 Radio",
        "name": ".Siklu T200 Radio",
        "description": "[network-tool]\nmanufacturer = [ \"Siklu\" ]\ndevice_role = [ \"Radio Link\" ]\ndevice_types = [ \"MH-T200-CNN-PoE-MWB\", \"MH-T200-CCC-PoE-MWB\" ]\n\n# Siklu template → model mapping (verified by live SNMP walk):\n# .Siklu EH Radio:   EH-600T/TX, EH-614TX, EH-1200/F/FX/L/TL/TX, EH-2200F/FX, EH-2500F/FX, EH-5500FD, EH-8010FX/L/H → .31926.2.*\n# .Siklu MH Radio:   MH-T280, MH-N366(?), ML2.5-60-35(?) → .31926.35.* HC-64bit\n# .Siklu B100 Radio: MH-B100-CCS-PoE-MWB → .31926.27.1.*/27.4.* 32-bit\n# .Siklu T200 Radio: MH-T200-CNN/CCC-PoE-MWB → .31926.27.2.* 32-bit\n# MH-N366/ML2.5-60-35: unverified — check live walk before migration",
        "templates": [
          {
            "name": ".Siklu Generic by SNMP"
          }
        ],
        "groups": [
          {
            "name": "Siklu"
          },
          {
            "name": "ITcare"
          },
          {
            "name": "Templates/Wireless"
          }
        ],
        "items": [
          {
            "uuid": "30226ae689c2402d98f4fafb77bb2aa9",
            "name": "System temperature",
            "type": "SNMP_AGENT",
            "snmp_oid": "get[1.3.6.1.4.1.31926.1.2.0]",
            "key": "sensor.temp.value[rbSysTemperature.0]",
            "delay": "{$HEALTH_POLL_INT}",
            "history": "{$HISTORY}",
            "trends": "{$TRENDS}",
            "units": "°C",
            "value_type": "FLOAT",
            "description": "MIB: SIKLU-MIB\nsikluSysTemperature.0 — same OID as EH/B100.",
            "preprocessing": [
              {
                "type": "DISCARD_UNCHANGED_HEARTBEAT",
                "parameters": [
                  "3m"
                ]
              }
            ],
            "tags": [
              {
                "tag": "component",
                "value": "temperature"
              }
            ],
            "triggers": [
              {
                "uuid": "5fadd602126249ca9863b85772dd0241",
                "expression": "avg(/.Siklu T200 Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})>{$TEMP_WARN}",
                "recovery_mode": "RECOVERY_EXPRESSION",
                "recovery_expression": "max(/.Siklu T200 Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})<{$TEMP_WARN}-3",
                "name": "Siklu T200: Temperature is above warning threshold",
                "event_name": "Siklu T200: Temperature {ITEM.LASTVALUE1} is above warning threshold: >{$TEMP_WARN}°C",
                "opdata": "Current: {ITEM.LASTVALUE1}",
                "priority": "WARNING",
                "manual_close": "YES",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "performance"
                  }
                ]
              },
              {
                "uuid": "767fad87b3054a9e96b246e04ecbb0c6",
                "expression": "avg(/.Siklu T200 Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})>{$TEMP_CRIT}",
                "recovery_mode": "RECOVERY_EXPRESSION",
                "recovery_expression": "max(/.Siklu T200 Radio/sensor.temp.value[rbSysTemperature.0],{$HEALTH_TRIGGER_INT})<{$TEMP_CRIT}-3",
                "name": "Siklu T200: Temperature is above critical threshold",
                "event_name": "Siklu T200: Temperature {ITEM.LASTVALUE1} is above critical threshold: >{$TEMP_CRIT}°C",
                "opdata": "Current: {ITEM.LASTVALUE1}",
                "priority": "HIGH",
                "manual_close": "YES",
                "tags": [
                  {
                    "tag": "scope",
                    "value": "performance"
                  }
                ]
              }
            ]
