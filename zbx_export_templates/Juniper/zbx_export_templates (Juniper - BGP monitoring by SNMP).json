                        "trigger_prototypes": [
                            {
                                "uuid": "2818bd3d13ff413c888100d9dc357f40",
                                "expression": "last(/.Juniper - BGP monitoring by SNMP/juniper.bgp.established.time[jnxBgpM2PeerFsmEstablishedTime.{#SNMPINDEX}]) < {$ADJACENCY4T}\nand\nlast(/.Juniper - BGP monitoring by SNMP/juniper.bgp.established.time[jnxBgpM2PeerFsmEstablishedTime.{#SNMPINDEX}]) > 0\nand\nlast(/.Juniper - BGP monitoring by SNMP/juniper.bgp.state[jnxBgpM2PeerState.{#SNMPINDEX}]) = 6",
                                "name": "Juniper: BGP AS [{#BGPM2_PEER_REMOTE_AS}] Peer [{#BGPM2_PEER_REMOTE_ADDR}]: uptime LOW",
                                "opdata": "Uptime: {ITEM.LASTVALUE}",
                                "priority": "INFO",
                                "description": "BGP session with peer {#BGPM2_PEER_REMOTE_ADDR} (AS{#BGPM2_PEER_REMOTE_AS}) has been established for less than {$ADJACENCY4T}.",
                                "manual_close": "YES",
                                "tags": [
