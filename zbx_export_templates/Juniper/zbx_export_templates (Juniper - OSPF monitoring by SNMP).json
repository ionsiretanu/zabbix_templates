                                    {
                                        "tag": "address",
                                        "value": "{#OSPF_IP_ADDR}"
                                    },
                                    {
                                        "tag": "component",
                                        "value": "network"
                                    },
                                    {
                                        "tag": "component",
                                        "value": "ospf"
                                    }
                                ],
                                "trigger_prototypes": [
                                    {
                                        "uuid": "d65716815ade49d6b9590d563ce30c61",
                                        "expression": "last(/.Juniper - OSPF monitoring by SNMP/juniper.ospf.state[ospfNbrState.{#SNMPINDEX}]) = 1",
                                        "name": "Juniper: OSPF neighbor [{#OSPF_IP_ADDR}] is DOWN",
                                        "opdata": "Current state: {ITEM.LASTVALUE1}",
                                        "status": "DISABLED",
                                        "priority": "AVERAGE",
                                        "description": "OSPF neighbor [{#OSPF_IP_ADDR}] in operational state `down`."
                                    },
                                    {
                                        "uuid": "810166140688475ca756c92a4adc8e9a",
                                        "expression": "(last(/.Juniper - OSPF monitoring by SNMP/juniper.ospf.state[ospfNbrState.{#SNMPINDEX}],#1) <> 8 and\nlast(/.Juniper - OSPF monitoring by SNMP/juniper.ospf.state[ospfNbrState.{#SNMPINDEX}],#2) <> 8)\nor\nnodata(/.Juniper - OSPF monitoring by SNMP/juniper.ospf.state[ospfNbrState.{#SNMPINDEX}],1m)=1",
                                        "name": "Juniper: OSPF neighbor [{#OSPF_IP_ADDR}] state is not FULL",
                                        "opdata": "Current state: {ITEM.LASTVALUE1}",
                                        "priority": "HIGH",
                                        "description": "OSPF neighbor [{#OSPF_IP_ADDR}] in operational state `init`.\ndown (1),\nattempt (2),\ninit (3),\ntwoWay (4),\nexchangeStart (5),\nexchange (6),\nloading (7),\nfull (8)",
                                        "manual_close": "YES"
                                    }
                                ]
                            }
