                                        "tag": "address",
                                        "value": "{#OSPF_IP_ADDR}"
                                    },
                                    {
                                        "tag": "component",
                                        "value": "network"
                                    },
                                    {
                                        "tag": "component",
                                        "value": "ospf"
                                    }
                                ],
