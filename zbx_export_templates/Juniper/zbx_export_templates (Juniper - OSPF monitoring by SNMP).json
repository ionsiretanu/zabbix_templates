                            {
                                "uuid": "8f12ba209fb247f084eefbdbc4326da7",
                                "name": "OSPF Neighbor [{#OSPF_IP_ADDR}]: Events",
                                "type": "DEPENDENT",
                                "key": "juniper.ospf.events[ospfNbrEvents.{#SNMPINDEX}]",
                                "history": "{$HISTORY}",
                                "value_type": "FLOAT",
                                "trends": "{$TRENDS}",
                                "description": "The number of times this neighbor relationship has changed state, or an error has occurred.",
                                "preprocessing": [
                                    {
                                        "type": "SNMP_WALK_VALUE",
                                        "parameters": [
