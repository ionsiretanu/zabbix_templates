                                "key": "juniper.ospf.state[ospfNbrState.{#SNMPINDEX}]",
                                "history": "{$HISTORY}",
                                "value_type": "FLOAT",
                                "trends": "{$TRENDS}",
                                "description": "The state of the relationship with this neighbor.",
                                "valuemap": {
                                    "name": "OSPF-MIB::ospfNbrState"
